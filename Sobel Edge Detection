#Load and define numpy
import numpy as np
#Call image loading function from Pillow
from PIL import Image
#Load and define Pycuda library
import pycuda.driver as cuda
import pycuda.autoinit
from pycuda.compiler import SourceModule
#Load time library for CPU vs GPU comparison
import time

#Find and load image, and define it as a variable, interpreet it in greyscale mode
img = Image.open(r"C:\Users\TryDo\Downloads\pexels-jplenio-1146708.jpg").convert("L")
#Convert the image into a NumPy matrix as float32 type
arr = np.array(img, dtype=np.float32)
#Define the height and width of the image.
height, width = arr.shape

#Allocate GPU memory
#Create an GPU side array that is the same size as the image
img_gpu = cuda.mem_alloc(arr.nbytes)
#Copy NumPy array from CPU to GPU memory
cuda.memcpy_htod(img_gpu, arr)
#Allocate another GPU buffer that will store the blurred image
out_gpu = cuda.mem_alloc(arr.nbytes)

# CUDA Kernel, now with shared memory
#SourceModule is a function that compiles all of our CUDA C code.
mod = SourceModule("""
#include <stdio.h>

//Computer each block as an 8x8 chunk
#define TILE_SIZE 8
//Radius for a 3x3 filter                   
#define R 1   

__global__ void Sobel_Shared(float* input, float* output, int width, int height)
{

    //Creates fast on-chip memory per block               
    extern __shared__ float tile[];
                   
    //Map each thread knows its location
    int tx = threadIdx.x;
    int ty = threadIdx.y;

    //Map each thread to a pixel
    int row_o = blockIdx.y * blockDim.y + ty;
    int col_o = blockIdx.x * blockDim.x + tx;

    //Shared memory width
    int shared_w = blockDim.x + 2 * R;
    int shared_h = blockDim.y + 2 * R;

    #define TILE(y,x) tile[(y) * shared_w + (x)]

    // Load tile + halo
    for (int y = ty; y < shared_h; y += blockDim.y)
    {
        for (int x = tx; x < shared_w; x += blockDim.x)
        {
            //Maps shared tile coord to global image coords
            int row_i = blockIdx.y * blockDim.y + y - R;
            int col_i = blockIdx.x * blockDim.x + x - R;

            //Handles boundaries by copying pixel if it is inside image
            if (row_i >= 0 && row_i < height && col_i >= 0 && col_i < width)
                TILE(y,x) = input[row_i * width + col_i];
            else
                TILE(y,x) = 0.0f;
        }
    }

    //Waits for all threads to finish loading
    __syncthreads();

    //Prevents out of bound writing at the edges               
    if (row_o < height && col_o < width)
    {
        //Gradient filter           
        float Gx[3][3] = {
            {-1, 0, 1},
            {-2, 0, 2},
            {-1, 0, 1}
        };
        //Gradient filter
        float Gy[3][3] = {
            {-1, -2, -1},
            { 0,  0,  0},
            { 1,  2,  1}
        };
        //Store horizontal and vertical gradient
        float sx = 0.0f;
        float sy = 0.0f;

        for (int i = 0; i < 3; i++)
        {
            for (int j = 0; j < 3; j++)
            {
                //Load pixel from shared memory
                float val = TILE(ty + i, tx + j);
                //Apply Sobel weights for horizontal and vertical gradient
                sx += val * Gx[i][j];
                sy += val * Gy[i][j];
            }
        }
        //Compute the final edge magnitude
        output[row_o * width + col_o] = sqrtf(sx * sx + sy * sy);
    }
}
""")

#Connects Python code to compiled CUDA kernel, and lets us execute the GPU code
func = mod.get_function("Sobel_Shared")


#Establish the blocks and grid
#Allow for non-square support
block_size = (16, 4, 1)  

grid_size = (
    (width + block_size[0] - 1) // block_size[0],
    (height + block_size[1] - 1) // block_size[1]
)

R = 1
#Calcuate how much dynamic shared memoery the kernel needs per block
shared_mem = (block_size[0] + 2*R) * (block_size[1] + 2*R) * np.float32().nbytes

#H2D Transfer timing
start = time.time()
cuda.memcpy_htod(img_gpu, arr)
h2d_time = time.time() - start


#GPU shared memory timing
start_event = cuda.Event()
end_event = cuda.Event()

#Start recording time
start_event.record()

#Call shared memory function
func(img_gpu,out_gpu,np.int32(width),np.int32(height),block=block_size,
     grid=grid_size,shared=shared_mem)

#Synchronize threads for better time accuracy
end_event.record()
end_event.synchronize()

#Record time and convert to seconds
gpu_shared_time = start_event.time_till(end_event) * 1e-3 


#D2H Transfer timing
start = time.time()

#Create a new NumPy array
gpu_result = np.empty_like(arr)
#Device to host copy
cuda.memcpy_dtoh(gpu_result, out_gpu)

d2h_time = time.time() - start

#Normalize Sobel output
gpu_result_norm = np.clip(gpu_result, 0, 255)
#Save image after Sobel edge detection
Image.fromarray(gpu_result_norm.astype(np.uint8)).save("gpu_sobel.jpg")

#CPU Sobel Edge Detection Function
def sobel_cpu(image):

    #Sobel horizontal gradient kernel
    Gx = np.array([
        [-1, 0, 1],
        [-2, 0, 2],
        [-1, 0, 1]
    ], dtype=np.float32)

    #Sobel vertical gradient kernel
    Gy = np.array([
        [-1, -2, -1],
        [ 0,  0,  0],
        [ 1,  2,  1]
    ], dtype=np.float32)

    #Image dimensions
    height, width = image.shape

    #Output image
    output = np.zeros_like(image, dtype=np.float32)

    #Pad image to handle boundaries
    padded = np.pad(image, pad_width=1, mode='constant', constant_values=0)

    #Loop through every pixel
    for y in range(height):
        for x in range(width):

            #Store horizontal and vertical gradients
            sx = 0.0
            sy = 0.0

            #Apply 3x3 Sobel filters
            for i in range(3):
                for j in range(3):

                    pixel = padded[y + i, x + j]

                    sx += pixel * Gx[i, j]
                    sy += pixel * Gy[i, j]

            #Compute edge magnitude
            output[y, x] = np.sqrt(sx * sx + sy * sy)

    return output


#Start CPU timer
start = time.time()

#Run CPU Sobel Function
cpu_result = sobel_cpu(arr)

#Record time
cpu_time = time.time() - start

#Normalize CPU Sobel output
cpu_result_norm = np.clip(cpu_result, 0, 255)

#Convert normalize result to image format
Image.fromarray(cpu_result_norm.astype(np.uint8)).save("cpu_sobel.jpg")


#Print out all results and comparisons
print("\n--- PERFORMANCE RESULTS ---")
print(f"CPU Sobel Edge Detection Time: {cpu_time:.6f} seconds")

print("\n--- GPU TIMINGS ---")
print(f"H2D Transfer Time: {h2d_time:.6f} seconds")
print(f"D2H Transfer Time: {d2h_time:.6f} seconds")

print("\n--- KERNEL TIMES ---")
print(f"GPU Shared Memory Time: {gpu_shared_time:.6f} seconds")

print("\n--- SPEEDUPS ---")
print(f"CPU vs Shared Speedup: {cpu_time / gpu_shared_time:.6f}x")

print(f"\nTotal GPU Time: {h2d_time + gpu_shared_time + d2h_time:.6f} seconds")
