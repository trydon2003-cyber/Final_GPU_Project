#Load and define numpy
import numpy as np
#Call image loading function from Pillow
from PIL import Image
#Load and define Pycuda library
import pycuda.driver as cuda
import pycuda.autoinit
from pycuda.compiler import SourceModule
#Load time library for CPU vs GPU comparison
import time

#Find and load image, and define it as a variable, interpreet it in greyscale mode
img = Image.open(r"C:\Users\TryDo\Downloads\pexels-jplenio-1146708.jpg").convert("L")
#Convert the image into a NumPy matrix as float32 type
arr = np.array(img, dtype=np.uint8)
#Define the height and width of the image.
height, width = arr.shape
size = height * width

#Allocate GPU memory
#Create an GPU side array that is the same size as the image
img_gpu = cuda.mem_alloc(arr.nbytes)

#Allocate another GPU buffer that will store the blurred image
out_gpu = cuda.mem_alloc(arr.nbytes)

#Histogram and CDF buffers
#Create space on the GPU for the histogram
hist_gpu = cuda.mem_alloc(256 * np.int32().nbytes)
#Create space on the GPU for the Cumulative Distribution Function
cdf_gpu  = cuda.mem_alloc(256 * np.int32().nbytes)
#Initialize histogram on GPU
cuda.memset_d32(hist_gpu, 0, 256)

#Copy NumPy array from CPU to GPU memory
cuda.memcpy_htod(img_gpu, arr)

# CUDA Kernel, now with shared memory
#SourceModule is a function that compiles all of our CUDA C code.
mod = SourceModule("""
#include <stdio.h>

//Constant histogram size               
#define BINS 256

//Kernel 1: Shared Memory Histogram
__global__ void histogram_kernel(unsigned char* input, int* hist, int size)
{
    //Creates histogram inside fast shared memory
    __shared__ int local_hist[256];

    //Each thread is mapped to local index inside the block
    int tid = threadIdx.x;
    //Compute which image pixel this thread processess
    int idx = blockIdx.x * blockDim.x + tid;

    //Initialize shared histogram memory
    for (int i = tid; i < 256; i += blockDim.x)
        local_hist[i] = 0;

    //Force all threads in block to wait, prevents race conditions
    __syncthreads();
                   
  if (idx < size)
    {
        //Load grayscale pixel
        unsigned char pixel = input[idx];
        //Increment the histogram bin
        atomicAdd(&local_hist[pixel], 1);
    }
                   
    //Ensure histogram update is complete
    __syncthreads();

    if (tid < 256)
        //Merge into global histogram
        atomicAdd(&hist[tid], local_hist[tid]);
}

//Kernel 2: Equalization                   
__global__ void equalization_kernel(unsigned char* input,unsigned char* output, int* cdf,
int size,int cdf_min)
{
    //Create unique global pixel index per thread
    int idx = blockIdx.x * blockDim.x + threadIdx.x;

   if (idx < size)
    {
        int pixel = input[idx];

        //Normalize histogram equaliztion
        float denom = (float)(size - cdf_min);
        //Prevents divide by zero errors
        if (denom < 1.0f) denom = 1.0f;

        //Histogram equalization formula, redistributes intensities.
        float value = ((cdf[pixel] - cdf_min) / denom) * 255.0f;
                   
        //Prevent invalid negative intensities
        if (value < 0) value = 0;
        //Prevents overflow beyound 8-bit
        if (value > 255) value = 255;

        output[idx] = (unsigned char)value;
    }
}
""")

#Connects Python code to compiled CUDA kernel, and lets us execute the GPU code
hist = mod.get_function("histogram_kernel")
eq = mod.get_function("equalization_kernel")


#Establish the blocks and grid
block_size = (256, 1, 1)  

grid_size = (
    (size + block_size[0] - 1) // block_size[0],
    1,
    1
)


#H2D Transfer timing
start = time.time()
cuda.memcpy_htod(img_gpu, arr)
h2d_time = time.time() - start


#GPU shared memory timing
start_event = cuda.Event()
end_event = cuda.Event()

#Start recording time
start_event.record()

#Run histogram kernl
hist(img_gpu, hist_gpu, np.int32(size),block=block_size, grid=grid_size)

#Create CPU histogram array
hist_cpu = np.zeros(256, dtype=np.int32)
#Copy histogram from GPU to CPU
cuda.memcpy_dtoh(hist_cpu, hist_gpu)

#Compute the CDF
cdf = np.cumsum(hist_cpu).astype(np.int32)

#Initialize minimum non-zero CDF
cdf_min = 0
#Iterates through the CDF
for v in cdf:
    #Make sure the CDF has a value
    if v != 0:
        #Store first non-zero cumulative frequency
        cdf_min = v
        break

#Send the CDF to the GPU
cuda.memcpy_htod(cdf_gpu,cdf)

#Run equalization kernel
eq(img_gpu, out_gpu, cdf_gpu,np.int32(size), np.int32(cdf_min),block=block_size, grid=grid_size)

#Synchronize threads for better time accuracy
end_event.record()
end_event.synchronize()

#Record time and convert to seconds
gpu_time = start_event.time_till(end_event) * 1e-3 

#Create an empty array
result = np.empty_like(arr)
#Copy data from GPU to CPU
cuda.memcpy_dtoh(result, out_gpu)

#Save new image result
Image.fromarray(result).save("gpu_equalized.jpg")

#D2H Transfer timing
end_event.record()
end_event.synchronize()

start = time.time()

# Create output buffer
gpu_result = np.empty_like(arr)

# Copy final equalized image back to host
cuda.memcpy_dtoh(gpu_result, out_gpu)

d2h_time = time.time() - start


