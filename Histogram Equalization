#Allocate GPU memory
#Create an GPU side array that is the same size as the image
img_gpu = cuda.mem_alloc(arr.nbytes)
#Copy NumPy array from CPU to GPU memory
cuda.memcpy_htod(img_gpu, arr)
#Allocate another GPU buffer that will store the blurred image
out_gpu = cuda.mem_alloc(arr.nbytes)

# CUDA Kernel, now with shared memory
#SourceModule is a function that compiles all of our CUDA C code.
mod = SourceModule("""
#include <stdio.h>

//Constant histogram size               
#define BINS 256

//KERNEL 1: SHARED MEMORY HISTOGRAM (BLOCK-LOCAL)
__global__ void histogram_kernel(unsigned char* input,int* global_hist,int size)
{
    
    //Allocate shared memory per block
    __shared__ int local_hist[BINS];

    //Thread index inside the block
    int tid = threadIdx.x;
    //Computes global pixel index
    int idx = blockIdx.x * blockDim.x + tid;

    //Initialize shared histogram
    if (tid < BINS)
        local_hist[tid] = 0;
    
    //Ensure all threads finish initialization
    __syncthreads();

    //Build block-local histogram
    if (idx < size)
    {
        //Read pixel intensity
        unsigned char pixel = input[idx];

        //Increments histogram bin and prevents race conditions
        atomicAdd(&local_hist[pixel], 1);
    }

    //Ensure all pixels are processed
    __syncthreads();

    
    //Merge into global histogram
    if (tid < BINS)
    {
        //Each block constributes its histrogram
        atomicAdd(&global_hist[tid], local_hist[tid]);
    }
}
""")

#Connects Python code to compiled CUDA kernel, and lets us execute the GPU code
func = mod.get_function("histrogram_kernl")


#Establish the blocks and grid
